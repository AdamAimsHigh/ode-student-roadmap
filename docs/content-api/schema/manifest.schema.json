{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stapleseducation.com/schemas/content/v1/manifest.schema.json",
  "title": "content/manifest.json — the unit registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "units"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.]+)?$",
      "description": "Semver of the content schema every file in content/ conforms to. Single-sourced here."
    },
    "units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["unitNumber", "slug", "status"],
        "properties": {
          "unitNumber": { "$ref": "common.defs.schema.json#/$defs/unitNumber" },
          "slug": { "$ref": "common.defs.schema.json#/$defs/unitSlug" },
          "status": {
            "type": "object",
            "additionalProperties": false,
            "required": ["guide", "practice", "quizzes"],
            "properties": {
              "guide": { "$ref": "#/$defs/fileStatus" },
              "practice": { "$ref": "#/$defs/fileStatus" },
              "quizzes": { "$ref": "#/$defs/fileStatus" }
            },
            "description": "Compilers MUST refuse to emit a target whose required file is 'missing'."
          },
          "provenance": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "guide": { "enum": ["authored", "backfill"] },
              "practice": { "enum": ["authored", "backfill"] },
              "quizzes": { "enum": ["authored", "backfill"] }
            },
            "description": "'backfill' marks archival-quality content recovered from generated artifacts (e.g. units 0-9 guides)."
          }
        }
      }
    }
  },
  "$defs": {
    "fileStatus": { "enum": ["complete", "partial", "missing"] }
  }
}
